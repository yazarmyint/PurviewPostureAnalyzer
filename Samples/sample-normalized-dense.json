  "sections": [
    {
      "id": "Sensitivity_Labels",
      "title": "Sensitivity Labels",
      "group": "Microsoft Information Protection",
      "groupIcon": "fas fa-shield-alt",
      "glance": { "status": "Improvement", "name": "Sensitivity Labels", "metric": "8 labels", "sub": "3 policies - auto-label in sim" },
      "findings": [
        {
          "id": "LABELS-01",
          "domId": "d-lab-1",
          "title": "Taxonomy is defined",
          "status": "Informational",
          "whyline": "A clear, ordered taxonomy is the foundation auto-labeling, DLP and retention build on. The tenant defines:",
          "table": {
            "columns": ["Label", "Priority", "Scope", "Status"],
            "rows": [
              { "cells": ["Public", "0", "Files, Emails"], "status": "Informational" },
              { "cells": ["General", "1", "Files, Emails"], "status": "Informational" },
              { "cells": ["Confidential", "2", "Files, Emails"], "status": "Informational" },
              { "cells": ["Highly Confidential", "3", "Files, Emails"], "status": "Informational" },
              { "cells": ["Highly Confidential \\ Legal", "3.1", "Files"], "status": "Informational", "indent": true },
              { "cells": ["Highly Confidential \\ Research", "3.2", "Files"], "status": "Informational", "indent": true },
              { "cells": ["Highly Confidential \\ Clinical", "3.3", "Files"], "status": "Informational", "indent": true },
              { "cells": ["Restricted", "4", "Files"], "status": "Informational" }
            ]
          },
          "learnmore": [
            { "label": "Microsoft Purview portal - Information Protection", "url": "https://purview.microsoft.com", "tag": "portal" },
            { "label": "Overview of sensitivity labels", "url": "https://learn.microsoft.com/en-us/purview/sensitivity-labels", "tag": "docs" }
          ]
        },
        {
          "id": "LABELS-02",
          "domId": "d-lab-2",
          "title": "Labels are published to users",
          "status": "OK",
          "whyline": "Labels only classify content once published to the people creating it.",
          "table": {
            "columns": ["Label Policy", "Labels", "Assigned To", "Status"],
            "rows": [
              { "cells": ["Contoso Global Label Policy", "Public, General, Confidential, Highly Confidential (+3 sub)", "All users"], "status": "OK" },
              { "cells": ["Executive Protection Policy", "Confidential, Highly Confidential, Restricted", "dl-exec@contosopharma.com"], "status": "OK" },
              { "cells": ["Research Label Policy", "Highly Confidential \\ Research, Highly Confidential \\ Clinical", "Research (grp)"], "status": "OK" }
            ]
          },
          "learnmore": [
            { "label": "Create and publish sensitivity labels", "url": "https://learn.microsoft.com/en-us/purview/create-sensitivity-labels", "tag": "docs" }
          ]
        },
        {
          "id": "LABELS-03",
          "domId": "d-lab-3",
          "title": "Auto-labeling is not enforcing",
          "status": "Improvement",
          "requires": "Microsoft 365 E5 (or Information Protection & Governance add-on)",
          "whyline": "Automatic labeling reduces reliance on users to classify correctly; in simulation it observes but never applies.",
          "table": {
            "columns": ["Auto-labeling Policy", "Conditions (SITs)", "Mode", "Status"],
            "rows": [
              { "cells": ["Auto-label PHI and PII", "U.S. HIPAA, U.S. SSN, Credit Card", "Simulation"], "status": "Improvement", "remark": "Auto-label PHI and PII has run in simulation since 14-Feb-2026 (137 days). Simulation shows 6,410 items would be labeled - consider turning the policy on." },
              { "cells": ["Auto-label Clinical Trial Data", "Custom SIT: Trial Protocol ID", "Simulation"], "status": "Improvement" }
            ]
          },
          "learnmore": [
            { "label": "Microsoft Purview portal - Information Protection", "url": "https://purview.microsoft.com", "tag": "portal" },
            { "label": "How to apply a sensitivity label to content automatically", "url": "https://learn.microsoft.com/en-us/purview/apply-sensitivity-label-automatically", "tag": "docs" }
          ]
        },
        {
          "id": "LABELS-04",
          "domId": "d-lab-4",
          "title": "No container labels for Teams / Sites / Groups",
          "status": "Recommendation",
          "whyline": "Container labels govern guest access, external sharing and unmanaged-device rules on collaborative workspaces.",
          "table": {
            "columns": ["Container type", "Coverage", "Status"],
            "rows": [
              { "cells": ["Microsoft 365 Groups / Teams", "0 of 212 labeled"], "status": "Recommendation" },
              { "cells": ["SharePoint sites", "0 of 245 labeled"], "status": "Recommendation" }
            ]
          },
          "learnmore": [
            { "label": "Use sensitivity labels to protect containers (groups & sites)", "url": "https://learn.microsoft.com/en-us/purview/sensitivity-labels-teams-groups-sites", "tag": "docs" }
          ]
        }
      ]
    },
    {
      "id": "Data_Loss_Prevention",
      "title": "Data Loss Prevention",
      "group": "Microsoft Information Protection",
      "groupIcon": "fas fa-shield-alt",
      "glance": { "status": "Improvement", "name": "Data Loss Prevention", "metric": "9 policies", "sub": "5 enforcing - Teams unscoped" },
      "findings": [
        {
          "id": "DLP-01",
          "domId": "d-dlp-1",
          "title": "9 DLP policies exist (5 enforcing, 4 in test)",
          "status": "Improvement",
          "whyline": "Policy count alone overstates protection; test-mode policies detect but don't block. Each policy:",
          "table": {
            "columns": ["DLP Policy", "Sensitive Information Type", "Remarks", "Status"],
            "rows": [
              { "cells": ["HIPAA - PHI Protection", "U.S. HIPAA, U.S. SSN", "Enforcing - EXO, SPO, ODB"], "status": "OK" },
              { "cells": ["PCI - Payment Cards", "Credit Card Number", "Enforcing - EXO, SPO, ODB"], "status": "OK" },
              { "cells": ["SSN Guard", "U.S. SSN", "Enforcing - EXO, SPO"], "status": "OK" },
              { "cells": ["Clinical Trial Data Guard", "Custom SIT: Trial Protocol ID", "Enforcing - SPO, ODB"], "status": "OK" },
              { "cells": ["Finance Data", "ABA Routing, U.S. Bank Account", "Enforcing - SPO, ODB"], "status": "OK" },
              { "cells": ["Broad PII Pilot", "Full Name, Email, Phone", "Test / simulation mode"], "status": "Improvement", "remark": "Broad PII Pilot has sat in test mode since 02-Mar-2026 - detects but does not block; incident digests go to svc-dlptest@contosopharma.onmicrosoft.com." },
              { "cells": ["GDPR - EU PII", "EU Passport, EU Driver's License", "Test / simulation mode"], "status": "Improvement" },
              { "cells": ["Source Code Guard", "Custom SIT: Repo Fingerprint", "Test / simulation mode"], "status": "Improvement" },
              { "cells": ["Legacy DLP", "U.S. SSN", "Test mode; 2 of 3 rules disabled"], "status": "Improvement" }
            ]
          },
          "learnmore": [
            { "label": "Microsoft Purview portal - Data Loss Prevention", "url": "https://purview.microsoft.com", "tag": "portal" },
            { "label": "Learn about data loss prevention", "url": "https://learn.microsoft.com/en-us/purview/dlp-learn-about-dlp", "tag": "docs" }
          ]
        },
        {
          "id": "DLP-02",
          "domId": "d-dlp-2",
          "title": "Teams is not in scope",
          "status": "Improvement",
          "requires": "Microsoft 365 E5 / Office 365 E5 (or Microsoft Purview Suite)",
          "whyline": "Sensitive data shared in Teams bypasses DLP entirely when Teams isn't a policy location.",
          "table": {
            "columns": ["Location", "In scope", "Status"],
            "rows": [
              { "cells": ["Exchange Online", "Yes (all policies)"], "status": "OK" },
              { "cells": ["SharePoint Online", "Yes"], "status": "OK" },
              { "cells": ["OneDrive", "Yes"], "status": "OK" },
              { "cells": ["Microsoft Teams", "No"], "status": "Improvement" }
            ]
          },
          "learnmore": [
            { "label": "Use DLP with Microsoft Teams", "url": "https://learn.microsoft.com/en-us/purview/dlp-microsoft-teams", "tag": "docs" }
          ]
        },
        {
          "id": "DLP-03",
          "domId": "d-dlp-3",
          "title": "Endpoint DLP is not configured",
          "status": "Improvement",
          "requires": "Microsoft 365 E5 (or Microsoft Purview Suite / IP&G add-on)",
          "whyline": "Without Endpoint DLP there's no control over copy-to-USB, print, or cloud-upload egress on managed devices.",
          "table": {
            "columns": ["Configuration", "Setting", "Status"],
            "rows": [
              { "cells": ["Devices onboarded", "0"], "status": "Improvement" },
              { "cells": ["Endpoint locations in policy", "None"], "status": "Improvement" }
            ]
          },
          "learnmore": [
            { "label": "Learn about Endpoint DLP", "url": "https://learn.microsoft.com/en-us/purview/endpoint-dlp-learn-about", "tag": "docs" }
          ]
        }
      ]
    },
