          ]
        },
        {
          "id": "AI-04",
          "domId": "d-ai-4",
          "title": "No DSPM collection policies",
          "status": "Informational",
          "whyline": "Collection policies extend DSPM visibility to enterprise and third-party AI apps; they sit above E5 (pay-as-you-go / Agent 365 billing), so absence is reported as context only.",
          "table": {
            "columns": ["Configuration", "Setting", "Status"],
            "rows": [
              { "cells": ["DSPM collection policies", "0"], "status": "Informational", "remark": "collection policies are billed pay-as-you-go / Agent 365; this line is inventory context, not a gap." }
