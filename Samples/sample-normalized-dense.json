    {
      "id": "DSPM_for_AI",
      "title": "DSPM for AI - Copilot Data Security",
      "group": "AI Security",
      "groupIcon": "fas fa-robot",
      "groupTag": "NEW",
      "glance": { "status": "Improvement", "name": "DSPM for AI", "metric": "1 policy", "sub": "simulation only - AI in scope" },
      "findings": [
        {
          "id": "AI-01",
          "domId": "d-ai-1",
          "title": "Copilot-scoped DLP artifacts present - AI surface in scope",
          "status": "Informational",
          "requires": "Microsoft 365 Copilot license",
          "whyline": "DLP policies scoped to the Microsoft 365 Copilot location exist, which puts AI data-security posture in scope for this tenant.",
          "table": {
            "columns": ["Configuration", "Setting", "Status"],
            "rows": [
              { "cells": ["Copilot-scoped DLP policies", "1"], "status": "Informational" }
            ]
          },
          "learnmore": [
            { "label": "Microsoft Purview portal - DSPM for AI", "url": "https://purview.microsoft.com", "tag": "portal" },
            { "label": "Data security for AI", "url": "https://learn.microsoft.com/en-us/purview/ai-microsoft-purview", "tag": "docs" }
          ]
        },
        {
          "id": "AI-02",
          "domId": "d-ai-2",
          "title": "Copilot DLP policy is in simulation mode",
          "status": "Improvement",
          "requires": "Prompt DLP: any Microsoft 365 Copilot tier; label-based file/email restriction: Microsoft 365 E5 (or Microsoft Purview Suite / IP&G add-on)",
          "whyline": "Visibility without control - the tenant can see risky AI interactions but isn't preventing them.",
          "table": {
            "columns": ["AI Policy", "Conditions", "Mode", "Status"],
            "rows": [
              { "cells": ["Detect sensitive info in AI prompts", "U.S. SSN, Credit Card, U.S. HIPAA", "Simulation (TestWithoutNotifications)"], "status": "Improvement", "remark": "Detect sensitive info in AI prompts is the one-click DSPM-for-AI default and ships in simulation - it has never been switched to enforce." }
            ]
          },
          "learnmore": [
            { "label": "Data Security Posture Management for AI", "url": "https://learn.microsoft.com/en-us/purview/dspm-for-ai", "tag": "docs" }
          ]
        },
        {
          "id": "AI-03",
          "domId": "d-ai-3",
          "title": "No label-based Copilot content exclusion",
          "status": "Recommendation",
          "whyline": "Without label-based exclusion, Copilot can process and surface labeled content users can technically open but shouldn't - oversharing risk.",
          "table": {
            "columns": ["Configuration", "Setting", "Status"],
            "rows": [
              { "cells": ["Copilot-location rules referencing sensitivity labels", "None detected"], "status": "Recommendation" },
              { "cells": ["Container/site-scoped sensitivity labels defined", "No"], "status": "Informational" }
            ]
          },
          "learnmore": [
            { "label": "DLP for Microsoft 365 Copilot and Copilot Chat", "url": "https://learn.microsoft.com/en-us/purview/dlp-microsoft365-copilot-location-learn-about", "tag": "docs" },
